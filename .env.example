# Gepetto-Browser environment — copy to `.env` (gitignored) or export in your shell.
# These are only needed for the OPTIONAL AI agent plugin (require('gepetto-browser/ai')).

# Anthropic API key for the AI agent. Get one at https://console.anthropic.com/
# The plugin also needs:  npm install @anthropic-ai/sdk
ANTHROPIC_API_KEY=

# Optional: path to a specific Chrome binary if the bundled one isn't found.
# GEPETTO_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
